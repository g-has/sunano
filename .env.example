NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

MAINTENANCE_MODE=false

# Supabase Auth email delivery
# Configure these values in your deployment environment and Supabase project SMTP settings.
SUPABASE_SMTP_HOST=
SUPABASE_SMTP_PORT=587
SUPABASE_SMTP_USER=
SUPABASE_SMTP_PASSWORD=
SUPABASE_SMTP_FROM="Sunano <no-reply@sunano.com>"

# YouTube Data API v3
# You can use any Google Cloud project/API key; it does not need to belong to the channel owner.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=@sunano_
# Optional: set directly to skip handle lookup
YOUTUBE_CHANNEL_ID=